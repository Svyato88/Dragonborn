{
  "multipart": [
    {
      "when": {
        "north": false,
        "east": false,
        "south": false,
        "west": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_none"
      }
    },




    {
      "when": {
        "north": true,
        "east": false,
        "south": false,
        "west": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_straight"
      }
    },
    {
      "when": {
        "east": true,
        "north": false,
        "south": false,
        "west": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_straight",
        "y": 90
      }
    },
    {
      "when": {
        "south": true,
        "north": false,
        "east": false,
        "west": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_straight",
        "y": 180
      }
    },
    {
      "when": {
        "west": true,
        "north": false,
        "east": false,
        "south": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_straight",
        "y": 270
      }
    },





    {
      "when": {
        "south": true,
        "east": true,
        "north": false,
        "west": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_inner",
        "y": 90
      }
    },
    {
      "when": {
        "north": true,
        "west": true,
        "east": false,
        "south": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_inner",
        "y": 270
      }
    },
    {
      "when": {
        "east": true,
        "north": true,
        "south": false,
        "west": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_inner"
      }
    },
    {
      "when": {
        "south": true,
        "east": false,
        "west": true,
        "north": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_inner",
        "y": 180
      }
    },





    {
      "when": {
        "south": true,
        "east": false,
        "north": true,
        "west": false
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_line",
        "y": 90
      }
    },
    {
      "when": {
        "south": false,
        "east": true,
        "north": false,
        "west": true
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_line"
      }
    },






    {
      "when": {
        "north": true,
        "east": true,
        "south": true
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_t",
        "y": 270
      }
    },
    {
      "when": {
        "north": true,
        "east": true,
        "west": true
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_t",
        "y": 180
      }
    },
    {
      "when": {
        "north": true,
        "south": true,
        "west": true
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_t",
        "y": 90
      }
    },
    {
      "when": {
        "east": true,
        "south": true,
        "west": true
      },
      "apply": {
        "model": "dragonborn:block/planks_wall_t"
      }
    },
    {
      "when": {
        "north": true,
        "east": true,
        "south": true,
        "west": true
      },
      "apply": {
        "model": "dragonborn:block/planks_all"
      }
    }
  ]
}


